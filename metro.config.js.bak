const { getDefaultConfig } = require("expo/metro-config");
const { withNativeWind } = require("nativewind/metro");

const config = getDefaultConfig(__dirname);

// Firebase 11+: @firebase/auth publishes a "react-native" export condition
// that returns a build without IndexedDB/window references. Prefer it over
// browser so the bundle doesn't hang at 99.9%.
config.resolver.unstable_enablePackageExports = true;
config.resolver.unstable_conditionNames = ["require", "react-native", "browser"];
config.resolver.sourceExts.push("cjs", "mjs");

module.exports = withNativeWind(config, { input: "./global.css" });
